# LiveKit (required for api + agent)
# Self-hosted example: wss://livekit.yourdomain.com or ws://localhost:7880
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Outbound SIP (required for api)
LIVEKIT_SIP_TRUNK_ID=

# Transcript handoff (required for agent)
SCREENING_API_BASE_URL=

